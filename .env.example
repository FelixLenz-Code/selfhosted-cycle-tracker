# ---- Datenbank ----
POSTGRES_USER=cycle
POSTGRES_PASSWORD=change_me
POSTGRES_DB=cycle
# Im Docker-Stack zeigt der Host auf den Service "db".
# Für lokale Entwicklung stattdessen: postgres://zyklus:zyklus_dev_pw@localhost:5433/zyklus
DATABASE_URL=postgres://cycle:change_me@db:5432/cycle

# ---- App ----
APP_PORT=3000
APP_TIMEZONE=Europe/Berlin
# true NUR hinter HTTPS setzen (sonst funktioniert der Login über http:// nicht)
COOKIE_SECURE=false
# Zufallswert: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change_me

# ---- Web Push / VAPID (erzeugen: npx web-push generate-vapid-keys) ----
# Public-Key wird zur Laufzeit an den Client gereicht (kein Build-Zeit-Baking nötig).
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# ---- Image-Tag (vom Installer gesetzt; sonst latest) ----
IMAGE_TAG=latest
